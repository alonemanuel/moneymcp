{
  "name": "moneymcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server to interact with your money via agents (Israeli bank data via israeli-bank-scrapers)",
  "scripts": {
    "scrape": "tsx scraper/src/index.ts",
    "login": "tsx scraper/src/login.ts",
    "build:scraper": "tsc",
    "typecheck": "tsc --noEmit",
    "worker:dev": "wrangler dev",
    "web:build": "npm --prefix web run build",
    "worker:deploy": "npm --prefix web run build && wrangler deploy",
    "worker:typecheck": "tsc -p worker/tsconfig.json"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "israeli-bank-scrapers": "^6.7.8",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260626.1",
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "wrangler": "^4.105.0"
  }
}
