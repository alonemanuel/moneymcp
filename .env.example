# Provider credentials (scraper). Copy to .env, fill in. NEVER commit .env.
# A provider is scraped only if all its vars are set, so you can enable
# institutions incrementally.

# Bank Hapoalim
HAPOALIM_USER_CODE=
HAPOALIM_PASSWORD=

# Isracard (credit card). NOTE: Isracard's anti-bot blocks headless scraping —
# run with SHOW_BROWSER=1 and a logged-in profile (see `npm run login -- isracard`).
ISRACARD_ID=
ISRACARD_CARD6=
ISRACARD_PASSWORD=

# Max (credit card) — currently parked
MAX_USERNAME=
MAX_PASSWORD=

# Cloudflare D1 write access (scraper -> D1 over REST). Not needed for --dry-run.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# Optional
# DAYS_BACK=10
# SHOW_BROWSER=1            # visible browser (required for Isracard)
# PROFILES_DIR=./.profiles  # base dir for per-provider trusted profiles
